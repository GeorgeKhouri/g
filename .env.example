# Rename to .env and fill in your values
PORT=3000
NODE_ENV=development

# Email configuration
OUTLOOK_USER=your-email@vaniercollege.qc.ca
OUTLOOK_APP_PASSWORD=your-outlook-app-password
LOIC_EMAIL=recipient@example.com
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false

# Database (leave empty for SQLite locally, Render sets DATABASE_URL automatically in production)
# DATABASE_URL=postgresql://user:password@localhost:5432/packages

# Optional: free persistent file storage via Supabase (recommended on Render)
# Create a public storage bucket and set these:
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=package-files

# Backup configuration
BACKUP_INTERVAL_MINUTES=15
BACKUP_RETENTION_DAYS=14
