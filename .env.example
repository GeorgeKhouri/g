# Rename to .env and fill in your values
PORT=3000
NODE_ENV=development

# Email configuration
OUTLOOK_USER=your-email@vaniercollege.qc.ca
OUTLOOK_APP_PASSWORD=your-outlook-app-password
LOIC_EMAIL=recipient@example.com

# Database (leave empty for SQLite locally, Render sets DATABASE_URL automatically in production)
# DATABASE_URL=postgresql://user:password@localhost:5432/packages

# Backup configuration
BACKUP_INTERVAL_MINUTES=15
BACKUP_RETENTION_DAYS=14
